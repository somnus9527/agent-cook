    "eslint-plugin-import": "^2.31.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.34.0"
  },
  "packageManager": "pnpm@9.0.0"
