# 复制为 .env.development / .env.production（已被 .gitignore 忽略，勿提交真实值）。
# 这里只放【密钥 / 机器级配置】；provider/model/baseURL 的偏好放 agent-cook.toml。
# 配置优先级：默认 < ~/.agent-cook/config.toml < ./agent-cook.toml < 环境变量(本文件) < CLI 参数

# 云端 provider 的密钥 —— 真实 key 放这里，由 agent-cook.toml 的 env_key 指向。绝不提交真实值。
MOONSHOT_API_KEY=

# 可选：临时覆盖（也可用 CLI 的 --provider/--model）
# AGENT_PROVIDER=kimi
# AGENT_MODEL=kimi-k2.6
# AGENT_MAX_STEPS=12
# AGENT_DATA_DIR=.agent-cook
