# Runtime provider: ollama or kimi.
AGENT_PROVIDER=ollama

# Ollama example: qwen3.5:2b
# Kimi example: kimi-k2.5
AGENT_MODEL=qwen3.5:2b

# Maximum ReAct loop steps per user turn.
AGENT_MAX_STEPS=12

# Runtime mode: react or plan-execute.
AGENT_MODE=react

# Checkpoint and trace output directory.
AGENT_DATA_DIR=.agent-cook

# Kimi/Moonshot OpenAI-compatible endpoint.
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# Never commit a real API key.
MOONSHOT_API_KEY=
